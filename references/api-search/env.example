# 阿里云 AccessKey（必填）
# 获取方式：https://help.aliyun.com/document_detail/311677.html
ALIBABA_CLOUD_ACCESS_KEY_ID=your_access_key_id
ALIBABA_CLOUD_ACCESS_KEY_SECRET=your_access_key_secret

# STS 临时凭证 Token（可选，使用 RAM 角色扮演时填写）
# ALIBABA_CLOUD_SECURITY_TOKEN=your_sts_token

# 明道云集成中心（api-search skill 使用）
# 获取方式：浏览器登录 https://www.dedlion.com → DevTools → Application → Cookies → md_pss_id
DEDLION_TOKEN=your_md_pss_id_cookie_value
# DevTools → Application → Local Storage → https://www.dedlion.com → currentProjectId
DEDLION_COMPANY_ID=your_company_id
# 可选，默认 https://www.dedlion.com
# DEDLION_BASE_URL=https://www.dedlion.com
